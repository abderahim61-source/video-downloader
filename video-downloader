<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>منصة بلال لتحميل الفيديوهات والأدوات الذكية</title>
    <!-- الخطوط والأيقونات الاحترافية -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --primary-color: #00b4d8;
            --secondary-color: #0077b6;
            --bg-color: #0f172a;
            --card-bg: #1e293b;
            --text-color: #f8fafc;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Cairo', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* الهيدر */
        header {
            background-color: var(--card-bg);
            padding: 15px 20px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 22px;
            font-weight: 700;
            color: var(--primary-color);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* حاوية الإعلانات العلوية - أساسية للربح */
        .ad-container-top {
            width: 95%;
            max-width: 728px;
            min-height: 90px;
            background: rgba(255, 255, 255, 0.05);
            margin: 20px auto;
            border: 1px dashed rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #94a3b8;
            font-size: 14px;
        }

        /* الحاوية الرئيسية للمحتوى */
        .main-content {
            flex: 1;
            max-width: 800px;
            width: 95%;
            margin: 0 auto 30px auto;
            text-align: center;
        }

        .hero-section {
            margin: 40px 0;
        }

        .hero-section h1 {
            font-size: 32px;
            margin-bottom: 10px;
            color: #ffffff;
        }

        .hero-section p {
            color: #94a3b8;
            font-size: 16px;
        }

        /* صندوق أداة التحميل */
        .downloader-box {
            background: var(--card-bg);
            padding: 30px;
            border-radius: 16px;
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.3);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .supported-icons {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 25px;
            font-size: 24px;
            color: #64748b;
        }

        .supported-icons i:hover {
            color: var(--primary-color);
            transform: scale(1.1);
            transition: all 0.2s;
        }

        .input-group {
            display: flex;
            gap: 10px;
            background: rgba(0, 0, 0, 0.2);
            padding: 8px;
            border-radius: 50px;
            border: 2px solid #334155;
            transition: border-color 0.3s;
        }

        .input-group:focus-within {
            border-color: var(--primary-color);
        }

        .input-group input {
            flex: 1;
            background: none;
            border: none;
            outline: none;
            color: white;
            padding: 0 15px;
            font-size: 16px;
        }

        .input-group button {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 50px;
            cursor: pointer;
            font-weight: 700;
            font-size: 16px;
            transition: opacity 0.2s;
        }

        .input-group button:hover {
            opacity: 0.9;
        }

        /* مساحة النتيجة */
        .result-area {
            margin-top: 25px;
            display: none;
            animation: slideUp 0.4s ease;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .download-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: #10b981;
            color: white;
            padding: 12px 25px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: bold;
            margin-top: 15px;
        }

        .download-btn:hover {
            background: #059669;
        }

        /* الفوتر والروابط القانونية لـ AdSense */
        footer {
            background-color: var(--card-bg);
            padding: 20px;
            text-align: center;
            font-size: 14px;
            color: #94a3b8;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .footer-links {
            margin-top: 10px;
            display: flex;
            justify-content: center;
            gap: 20px;
        }

        .footer-links a {
            color: #94a3b8;
            text-decoration: none;
        }

        .footer-links a:hover {
            color: var(--primary-color);
        }
    </style>
</head>
<body>

    <!-- هيدر الموقع -->
    <header>
        <div class="logo">
            <i class="fa-solid fa-cloud-arrow-down"></i>
            <span>منصة بلال للأدوات والتحميل</span>
        </div>
    </header>

    <!-- المساحة الإعلانية العلوية لـ AdSense المربحة جداً في هذا النوع من المواقع -->
    <div class="ad-container-top">
        <!-- ضع كود إعلان AdSense أو Monetag هنا لاحقاً -->
        مساحة إعلانية مخصصة للربح (تظهر الإعلانات هنا للزوار)
    </div>

    <!-- المحتوى الرئيسي للموقع -->
    <div class="main-content">
        <section class="hero-section">
            <h1>حمّل فيديوهاتك المفضلة بضغطة واحدة</h1>
            <p>أداة مجانية وسريعة للتحميل من مختلف المنصات بجودة عالية</p>
        </section>

        <!-- صندوق التحميل الذكي -->
        <div class="downloader-box">
            <div class="supported-icons">
                <i class="fa-brands fa-youtube" title="يوتيوب"></i>
                <i class="fa-brands fa-tiktok" title="تيك توك"></i>
                <i class="fa-brands fa-instagram" title="انستغرام"></i>
                <i class="fa-brands fa-facebook" title="فيسبوك"></i>
            </div>

            <div class="input-group">
                <input type="text" id="videoLink" placeholder="ضع رابط الفيديو أو المنشور هنا...">
                <button onclick="processDownload()">ابدأ التحميل</button>
            </div>

            <!-- مكان ظهور رابط التحميل والنتيجة للزائر -->
            <div class="result-area" id="resultArea">
                <p style="color: #10b981;"><i class="fa-solid fa-circle-check"></i> تم تجهيز الفيديو بنجاح!</p>
                <a href="#" id="downloadLink" class="download-btn" target="_blank" download>
                    <i class="fa-solid fa-download"></i> تحميل بجودة عالية HD
                </a>
            </div>
        </div>
    </div>

    <!-- الفوتر مع روابط الامتثال لسياسات جوجل وأدوات الخصوصية -->
    <footer>
        <p>&copy; 2026 جميع الحقوق محفوظة></p>
        <div class="footer-links">
            <a href="#">سياسة الخصوصية (Privacy Policy)</a>
            <a href="#">شروط الاستخدام</a>
            <a href="#">اتصل بنا</a>
        </div>
    </footer>

    <script>
        function processDownload() {
            const urlInput = document.getElementById('videoLink').value.trim();
            const resultArea = document.getElementById('resultArea');
            const downloadLink = document.getElementById('downloadLink');

            if (urlInput === "") {
                alert("من فضلك أدخل رابط فيديو صحيح أولاً!");
                return;
            }

            // محاكاة معالجة الرابط وتجهيزه للتحميل
            // عند ربط الموقع بـ API تحميل حقيقي، سيتم وضع الرابط المباشر المستخرج هنا
            resultArea.style.display = "block";
            downloadLink.href = urlInput; // كود تجريبي يفتح نفس الرابط
        }
    </script>
</body>
</html>
